# ============================================================================
# ENVIRONMENT VARIABLES - Copy this to .env and fill in your values
# ============================================================================

# Google OAuth (from Google Cloud Console > APIs & Credentials)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ============================================================================
# RAGFlow Configuration
# ----------------------------------------------------------------------------
# These are read at build time by Vite and used by the zero-config bootstrap.
# The API key can be found in RAGFlow Dashboard > User Settings > API Key,
# or queried from the database:
#   docker exec docker-mysql-1 mysql -u root -pinfini_rag_flow rag_flow \
#     -e "SELECT token FROM api_token LIMIT 1;"
# ============================================================================
VITE_RAGFLOW_DEFAULT_URL=http://localhost:9380
VITE_RAGFLOW_DEFAULT_API_KEY=
